---
import { en as t } from '../../i18n/translations';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const lastUpdated = 'March 28, 2026';
---

<Layout
  lang="en"
  title="Privacy Policy — Finixa"
  description="Finixa's privacy policy. How we collect, use and protect your personal data."
>
  <Navbar t={t.nav} />
  <main class="legal-main">
    <div class="container legal-container">

      <div class="legal-header">
        <a href="/en/" class="legal-back">← Back</a>
        <div class="section-label">Legal</div>
        <h1 class="legal-title">Privacy Policy</h1>
        <p class="legal-updated">Last updated: {lastUpdated}</p>
      </div>

      <div class="legal-body">

        <section class="legal-section">
          <h2>1. Who we are</h2>
          <p>Finixa is a personal budget management web app, developed and maintained by Owen Lebec. For any data-related enquiries, contact us at: <a href="mailto:contact@finixa.app">contact@finixa.app</a>.</p>
        </section>

        <section class="legal-section">
          <h2>2. Data we collect</h2>
          <p>Finixa only collects data you voluntarily enter:</p>
          <ul>
            <li><strong>Financial transactions</strong> — amounts, categories, labels and dates you enter manually.</li>
            <li><strong>App settings</strong> — theme preferences, custom categories, savings goals and budgets.</li>
            <li><strong>Login data</strong> — email address and password if you create an account (stored securely via Supabase).</li>
          </ul>
          <p>Finixa <strong>never connects to your bank</strong> and collects no banking credentials whatsoever.</p>
        </section>

        <section class="legal-section">
          <h2>3. Purpose of processing</h2>
          <p>Your data is used exclusively to:</p>
          <ul>
            <li>Run the application and display your personal dashboard.</li>
            <li>Sync your data across devices when signed in to an account.</li>
            <li>Improve the user experience (aggregated, anonymised analytics only).</li>
          </ul>
          <p>Your data is <strong>never sold</strong> to third parties or used for advertising purposes.</p>
        </section>

        <section class="legal-section">
          <h2>4. Hosting and security</h2>
          <p>Data is hosted on <strong>Supabase</strong> (PostgreSQL infrastructure on AWS), with encryption in transit (TLS) and at rest. Supabase complies with current security standards.</p>
        </section>

        <section class="legal-section">
          <h2>5. Data retention</h2>
          <p>Your data is kept for as long as your account is active. Upon account deletion, all your data is permanently erased within 30 days.</p>
        </section>

        <section class="legal-section">
          <h2>6. Your rights (GDPR)</h2>
          <p>Under the General Data Protection Regulation, you have the following rights:</p>
          <ul>
            <li><strong>Right of access</strong> — obtain a copy of your data.</li>
            <li><strong>Right to rectification</strong> — correct inaccurate data.</li>
            <li><strong>Right to erasure</strong> — delete your data ("right to be forgotten").</li>
            <li><strong>Right to portability</strong> — export your data (CSV export available in-app).</li>
            <li><strong>Right to object</strong> — object to certain processing activities.</li>
          </ul>
          <p>To exercise these rights, contact us at <a href="mailto:contact@finixa.app">contact@finixa.app</a>.</p>
        </section>

        <section class="legal-section">
          <h2>7. Cookies</h2>
          <p>Finixa only uses strictly necessary technical cookies for the application to function (user session, theme preference). No tracking or advertising cookies are used.</p>
        </section>

        <section class="legal-section">
          <h2>8. Changes to this policy</h2>
          <p>We reserve the right to update this policy at any time. In the event of a significant change, you will be notified via the application. The last updated date is shown at the top of this page.</p>
        </section>

        <section class="legal-section">
          <h2>9. Contact</h2>
          <p>For any questions regarding this policy or your personal data: <a href="mailto:contact@finixa.app">contact@finixa.app</a></p>
        </section>

      </div>
    </div>
  </main>
  <Footer t={t.footer} />
</Layout>

<style>
  .legal-main { padding-top: 120px; padding-bottom: 80px; min-height: 100vh; }
  .legal-container { max-width: 720px; }
  .legal-header { margin-bottom: 56px; }
  .legal-back {
    display: inline-flex; align-items: center;
    font-size: 13px; font-weight: 600; color: var(--text-muted);
    margin-bottom: 24px; transition: color var(--transition);
  }
  .legal-back:hover { color: var(--text); }
  .legal-title {
    font-size: clamp(32px, 5vw, 48px); font-weight: 800;
    letter-spacing: -0.04em; line-height: 1.1; color: var(--text); margin: 12px 0 8px;
  }
  .legal-updated { font-size: 13px; color: var(--text-muted); }
  .legal-body { display: flex; flex-direction: column; gap: 40px; }
  .legal-section h2 { font-size: 18px; font-weight: 700; letter-spacing: -0.02em; color: var(--text); margin-bottom: 12px; }
  .legal-section p, .legal-section li { font-size: 15px; line-height: 1.75; color: var(--text-muted); }
  .legal-section p + p { margin-top: 10px; }
  .legal-section ul { padding-left: 20px; margin: 10px 0; display: flex; flex-direction: column; gap: 6px; }
  .legal-section a { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
  .legal-section strong { color: var(--text); font-weight: 600; }
</style>
