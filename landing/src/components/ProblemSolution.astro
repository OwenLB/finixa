---
import type { Translations } from '../i18n/translations';
import Icon from './Icon.astro';

interface Props {
  t: Translations['problemSolution'];
}

const { t } = Astro.props;
---

<section class="section problem-solution" id="pourquoi">
  <div class="container">
    <div class="section-label">{t.sectionLabel}</div>

    <h2 class="ps-title reveal-up">
      {t.titleBefore} <span class="pencil-mark">{t.titleAccent}</span>
    </h2>

    <div class="ps-grid">

      <!-- Without app -->
      <div class="ps-col">
        <div class="ps-col-header ps-col-header-bad">
          <span class="ps-col-icon ps-col-icon-bad">✕</span>
          <span class="ps-col-label">{t.withoutLabel}</span>
        </div>
        <div class="chaos-stack">
          {t.withoutCards.map((card, i) => (
            <div class={`ps-card ps-card-bad ps-card-${i + 1}`}>
              <span class="ps-card-emoji"><Icon name={card.icon} size={20} /></span>
              <div class="ps-card-text">
                <strong>{card.title}</strong>
                <span>{card.sub}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Divider -->
      <div class="ps-divider" aria-hidden="true">
        <div class="ps-divider-line"></div>
        <div class="ps-divider-icon">→</div>
        <div class="ps-divider-line"></div>
      </div>

      <!-- With app -->
      <div class="ps-col">
        <div class="ps-col-header ps-col-header-good">
          <span class="ps-col-icon ps-col-icon-good">✓</span>
          <span class="ps-col-label">{t.withLabel}</span>
        </div>
        <div class="order-stack">
          {t.withCards.map(card => (
            <div class="ps-card ps-card-good">
              <span class="ps-card-emoji"><Icon name={card.icon} size={20} /></span>
              <div class="ps-card-text">
                <strong>{card.title}</strong>
                <span>{card.sub}</span>
              </div>
              <span class="ps-card-check">✓</span>
            </div>
          ))}
        </div>
      </div>

    </div>

    <blockquote class="philosophy">
      <div class="philosophy-icon">"</div>
      <p>{t.philosophy}</p>
      <cite>{t.philosophyCite}</cite>
    </blockquote>
  </div>
</section>

<style>
  .ps-title {
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin-bottom: 60px;
    max-width: 600px;
  }

  .ps-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 48px;
    align-items: start;
    margin-bottom: 80px;
  }

  .ps-col-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 28px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }

  .ps-col-icon {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .ps-col-icon-bad  { background: var(--surface-2); color: var(--text-subtle); }
  .ps-col-icon-good { background: var(--accent); color: var(--accent-contrast); }

  .ps-col-label { font-size: 14px; font-weight: 700; letter-spacing: -0.01em; }
  .ps-col-header-bad .ps-col-label  { color: var(--text-muted); }
  .ps-col-header-good .ps-col-label { color: var(--text); }

  .ps-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 16px;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--surface);
  }

  .ps-card-emoji { display: inline-flex; flex-shrink: 0; }
  /* Couleurs variées par carte */
  .chaos-stack .ps-card-1 .ps-card-emoji { color: var(--red); }
  .chaos-stack .ps-card-2 .ps-card-emoji { color: var(--orange); }
  .chaos-stack .ps-card-3 .ps-card-emoji { color: var(--purple); }
  .chaos-stack .ps-card-4 .ps-card-emoji { color: var(--blue); }
  .order-stack .ps-card-good:nth-child(1) .ps-card-emoji { color: var(--green); }
  .order-stack .ps-card-good:nth-child(2) .ps-card-emoji { color: var(--blue); }
  .order-stack .ps-card-good:nth-child(3) .ps-card-emoji { color: var(--orange); }
  .order-stack .ps-card-good:nth-child(4) .ps-card-emoji { color: var(--purple); }

  .ps-card-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }

  .ps-card-text strong { font-size: 14px; font-weight: 600; line-height: 1.3; }
  .ps-card-text span   { font-size: 12px; color: var(--text-muted); line-height: 1.4; }

  /* Chaos stack */
  .chaos-stack { position: relative; height: 320px; }

  .ps-card-bad {
    position: absolute;
    width: calc(100% - 32px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.2);
  }

  .ps-card-bad .ps-card-text strong { color: var(--text); }

  .ps-card-1 { top: 0px;   transform: rotate(-7deg) translateX(-18px); z-index: 1; }
  .ps-card-2 { top: 72px;  transform: rotate(5deg) translateX(22px);   z-index: 2; }
  .ps-card-3 { top: 144px; transform: rotate(-4deg) translateX(-10px); z-index: 3; }
  .ps-card-4 { top: 216px; transform: rotate(8deg) translateX(14px);   z-index: 4; }

  /* Order stack */
  .order-stack { display: flex; flex-direction: column; gap: 10px; }

  .ps-card-good {
    border-left: 3px solid var(--accent);
    transition: transform var(--transition);
  }

  .ps-card-good:hover { transform: translateX(4px); }
  .ps-card-good .ps-card-text strong { color: var(--text); }

  .ps-card-check {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--green-dim);
    color: var(--green-glow);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    flex-shrink: 0;
  }

  /* Divider */
  .ps-divider {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding-top: 52px;
    height: 100%;
  }

  .ps-divider-line { flex: 1; width: 1px; background: var(--border); min-height: 40px; }

  .ps-divider-icon {
    font-size: 18px;
    color: var(--text-muted);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /* Philosophy */
  .philosophy {
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 0 var(--radius) var(--radius) 0;
    padding: 32px 40px;
    background: var(--surface);
    position: relative;
  }

  .philosophy-icon {
    font-size: 64px;
    line-height: 1;
    color: var(--accent);
    opacity: 0.2;
    position: absolute;
    top: 16px;
    left: 24px;
    font-family: Georgia, serif;
  }

  .philosophy p {
    font-size: 18px;
    line-height: 1.7;
    color: var(--text);
    font-style: italic;
    margin-bottom: 16px;
    padding-left: 20px;
  }

  .philosophy cite {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    padding-left: 20px;
    font-style: normal;
  }

  @media (max-width: 800px) {
    .ps-grid { grid-template-columns: 1fr; gap: 32px; }

    .ps-divider {
      flex-direction: row;
      padding-top: 0;
      height: auto;
    }

    .ps-divider-line { flex: 1; height: 1px; width: auto; min-height: 0; }
    .ps-divider-icon { transform: rotate(90deg); }
    .chaos-stack { height: 320px; }
    .philosophy p { font-size: 15px; }
  }
</style>
