---
import type { Translations } from '../i18n/translations';
import Icon from './Icon.astro';

interface Props {
  t: Translations['creator'];
}

const { t } = Astro.props;
---

<section class="section creator" id="createur">
  <div class="container">
    <div class="creator-inner">
      <div class="creator-avatar">
        <div class="avatar-placeholder">
          <Icon name="code" size={42} />
        </div>
        <div class="creator-links">
          <a href="https://github.com/OwenLB" class="creator-link" aria-label="GitHub" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0012 2z"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/in/owenlb/" class="creator-link" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="https://owenlebec.fr/" class="creator-link" aria-label="Portfolio" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
              <circle cx="12" cy="12" r="10"/>
              <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
          </a>
          <a href="mailto:lebec.owen@yahoo.fr" class="creator-link" aria-label="Email">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="M2 7l10 7 10-7"/>
            </svg>
          </a>
        </div>
      </div>

      <div class="creator-content">
        <div class="section-label">{t.sectionLabel}</div>
        <h2 class="creator-name">Owen</h2>
        <p class="creator-role">{t.role}</p>
        <p class="creator-story">{t.story1}</p>
        <p class="creator-story">{t.story2}</p>
        <p class="creator-story creator-story-highlight">{t.story3}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .creator-inner {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 64px;
    align-items: start;
    max-width: 900px;
  }

  .creator-avatar { display: flex; flex-direction: column; align-items: center; gap: 20px; }

  .avatar-placeholder {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: var(--surface-2);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text);
  }

  .creator-links { display: flex; gap: 10px; }

  .creator-link {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    background: var(--surface-2);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    transition: color var(--transition), border-color var(--transition);
  }

  .creator-link:hover { color: var(--text); border-color: var(--border-hover); }

  .creator-name { font-size: clamp(36px, 5vw, 60px); font-weight: 800; letter-spacing: -0.04em; margin-bottom: 4px; }
  .creator-role  { font-size: 14px; color: var(--text-muted); margin-bottom: 28px; }

  .creator-story { font-size: 16px; line-height: 1.75; color: var(--text-muted); margin-bottom: 16px; }
  .creator-story-highlight { color: var(--text); font-weight: 500; font-style: italic; }

  @media (max-width: 720px) {
    .creator-inner { grid-template-columns: 1fr; gap: 36px; }
    .creator-avatar { flex-direction: row; }
  }
</style>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Owen",
  "jobTitle": t.role,
  "description": t.story2,
  "url": "https://finixa.app/#createur",
  "worksFor": {
    "@type": "Organization",
    "name": "Finixa",
    "url": "https://finixa.app"
  }
})} />
