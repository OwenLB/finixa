---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations['ctaMid'];
}

const { t } = Astro.props;
---

<section class="cta-mid">
  <div class="container cta-mid-inner">
    <p class="cta-mid-text reveal-up">{t.text}</p>
    <a href="https://app.finixa.net" class="btn-appstore cta-mid-btn reveal-up delay-1" aria-label={t.cta} rel="noopener noreferrer" target="_blank">
      {t.cta}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
        <path d="M7 17L17 7M17 7H8M17 7v9"/>
      </svg>
    </a>
  </div>
</section>

<style>
  .cta-mid {
    padding: 160px 0;
    text-align: center;
  }

  .cta-mid-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
  }

  .cta-mid-text {
    font-family: var(--font-display);
    font-size: clamp(34px, 6vw, 76px);
    font-weight: 500;
    letter-spacing: -0.04em;
    line-height: 1.02;
    color: var(--text);
    max-width: 14ch;
  }

  .cta-mid-btn {
    font-size: 15px;
    padding: 15px 32px;
  }
</style>
