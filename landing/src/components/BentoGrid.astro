---
import type { Translations } from '../i18n/translations';
import Icon from './Icon.astro';

interface Props {
  t: Translations['bento'];
}

const { t } = Astro.props;
---

<section class="section bento-section" id="features">
  <div class="container">
    <div class="section-label">{t.sectionLabel}</div>

    <h2 class="bento-title reveal-up">
      {t.titleBefore} <span class="pencil-mark">{t.titleAccent}</span><br />
      <span class="gradient-text">{t.titleLine2}</span>
    </h2>

    <div class="bento-grid">

      <!-- ① Ajout rapide — Hero 2×2 -->
      <div class="bento-cell bento-hero">
        <!-- Texte en haut -->
        <div class="hero-content">
          <div class="bento-label">{t.quickAdd.label}</div>
          <h3 class="hero-title">{t.quickAdd.title}</h3>
          <p class="bento-cell-desc">{t.quickAdd.desc}</p>
          <div class="ios-badge">
            <span class="ios-icon"><Icon name="smartphone" size={15} /></span>
            <span>{t.quickAdd.ios}</span>
          </div>
        </div>
        <!-- Panel du bas : entry UI + historique -->
        <div class="hero-panel">
          <div class="hp-left">
            <div class="hp-amount">
              <span class="hp-currency">€</span>
              <span class="hp-num">12,90</span>
            </div>
            <div class="hp-cat"><Icon name="utensils" size={14} /> Burger</div>
            <div class="hp-btn"><Icon name="check" size={14} /> {t.quickAdd.confirm}</div>
          </div>
          <div class="hp-divider"></div>
          <div class="hp-right">
            <div class="hp-sep-label">{t.quickAdd.addedToday}</div>
            <div class="hp-history">
              <div class="hp-tx">
                <span class="hp-tx-label"><Icon name="coffee" size={13} /> Café</span>
                <span class="hp-tx-amt">-4,50 €</span>
              </div>
              <div class="hp-tx">
                <span class="hp-tx-label"><Icon name="cart" size={13} /> Courses</span>
                <span class="hp-tx-amt">-32,10 €</span>
              </div>
              <div class="hp-tx">
                <span class="hp-tx-label"><Icon name="train" size={13} /> RER</span>
                <span class="hp-tx-amt">-3,90 €</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ② Swipe queue -->
      <div class="bento-cell bento-small bento-swipe">
        <div class="bento-label">{t.swipe.label}</div>
        <h3 class="bento-cell-title">{t.swipe.title}</h3>
        <div class="bento-visual">
          <div class="swipe-stack">
            <div class="swipe-card swipe-card-back">
              <span class="swipe-emoji"><Icon name="cart" size={22} /></span>
              <span class="swipe-name">LIDL 18/03</span>
            </div>
            <div class="swipe-card swipe-card-front">
              <span class="swipe-emoji"><Icon name="utensils" size={22} /></span>
              <span class="swipe-name">MC DO 15/03</span>
            </div>
          </div>
          <div class="swipe-hint">{t.swipe.hint}</div>
        </div>
      </div>

      <!-- ③ Cagnottes -->
      <div class="bento-cell bento-small bento-savings">
        <div class="bento-label">{t.savings.label}</div>
        <h3 class="bento-cell-title">{t.savings.title}</h3>
        <div class="bento-visual">
          <div class="savings-list">
            <div class="savings-goal">
              <div class="sg-header">
                <span class="sg-emoji"><Icon name="plane" size={16} /></span>
                <span class="sg-name">{t.savings.goal1}</span>
                <span class="sg-pct">75%</span>
              </div>
              <div class="sg-track">
                <div class="sg-fill" style="width:75%"></div>
              </div>
              <div class="sg-amounts">
                <span class="sg-current">750 €</span>
                <span class="sg-target">/ 1 000 €</span>
              </div>
            </div>
            <div class="savings-goal">
              <div class="sg-header">
                <span class="sg-emoji"><Icon name="car" size={16} /></span>
                <span class="sg-name">{t.savings.goal2}</span>
                <span class="sg-pct">40%</span>
              </div>
              <div class="sg-track">
                <div class="sg-fill" style="width:40%"></div>
              </div>
              <div class="sg-amounts">
                <span class="sg-current">2 000 €</span>
                <span class="sg-target">/ 5 000 €</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ④ Récurrentes -->
      <div class="bento-cell bento-small">
        <div class="bento-label">{t.recurring.label}</div>
        <h3 class="bento-cell-title">{t.recurring.title}</h3>
        <div class="bento-visual">
          <div class="recur-list">
            <div class="recur-item">
              <span class="recur-icon"><Icon name="home" size={16} /></span>
              <div class="recur-info">
                <span class="recur-name">{t.recurring.name1}</span>
                <span class="recur-freq">{t.recurring.freq1}</span>
              </div>
              <span class="recur-amount">-850 €</span>
            </div>
            <div class="recur-item">
              <span class="recur-icon"><Icon name="smartphone" size={16} /></span>
              <div class="recur-info">
                <span class="recur-name">{t.recurring.name2}</span>
                <span class="recur-freq">{t.recurring.freq2}</span>
              </div>
              <span class="recur-amount">-14 €</span>
            </div>
          </div>
        </div>
      </div>

      <!-- ⑤ Suggestion intelligente -->
      <div class="bento-cell bento-small bento-smart">
        <div class="bento-label">{t.smart.label}</div>
        <h3 class="bento-cell-title">{t.smart.title}</h3>
        <div class="bento-visual">
          <div class="smart-card">
            <!-- Transaction (haut) -->
            <div class="smart-header">
              <span class="smart-merchant">STARBUCKS</span>
              <div class="smart-meta-row">
                <span class="smart-meta">-5,60 €</span>
                <span class="smart-dot">·</span>
                <span class="smart-meta">20/03</span>
              </div>
            </div>
            <!-- Suggestion (bas, teinté violet) -->
            <div class="smart-body">
              <div class="smart-label-row">
                <span class="smart-spark"><Icon name="sparkles" size={13} /></span>
                <span class="smart-label-txt">{t.smart.suggestLabel}</span>
              </div>
              <div class="smart-actions">
                <span class="smart-chip"><Icon name="coffee" size={13} /> {t.smart.category}</span>
                <span class="smart-ok"><Icon name="check" size={13} /></span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ⑥ Répartition 50/30/20 — Medium 2×1 -->
      <div class="bento-cell bento-medium bento-split">
        <div class="bento-label">{t.split.label}</div>
        <h3 class="bento-cell-title">{t.split.title}</h3>
        <div class="split-bars">
          <div class="split-bar">
            <div class="split-row">
              <span class="split-name">{t.split.needs}</span>
              <span class="split-pct">72%</span>
            </div>
            <div class="split-track">
              <div class="split-fill" style="width:72%;background:var(--blue)"></div>
            </div>
          </div>
          <div class="split-bar">
            <div class="split-row">
              <span class="split-name">{t.split.wants}</span>
              <span class="split-pct">45%</span>
            </div>
            <div class="split-track">
              <div class="split-fill" style="width:45%;background:var(--orange)"></div>
            </div>
          </div>
          <div class="split-bar">
            <div class="split-row">
              <span class="split-name">{t.split.savings}</span>
              <span class="split-pct">60%</span>
            </div>
            <div class="split-track">
              <div class="split-fill" style="width:60%;background:var(--green)"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- ⑦ Import CSV -->
      <div class="bento-cell bento-small">
        <div class="bento-label">{t.csv.label}</div>
        <h3 class="bento-cell-title">{t.csv.title}</h3>
        <div class="bento-visual">
          <div class="import-badge">
            <span class="import-icon"><Icon name="folder" size={16} /></span>
            <span class="import-text">relevé_mars.csv</span>
            <span class="import-count">{t.csv.count}</span>
          </div>
        </div>
      </div>

      <!-- ⑧ Graphiques -->
      <div class="bento-cell bento-small bento-chart">
        <div class="bento-label">{t.dashboard.label}</div>
        <h3 class="bento-cell-title">{t.dashboard.title}</h3>
        <div class="bento-visual">
          <div class="mc-bars">
            <div class="mc-col">
              <div class="mc-bar" style="height:28px;background:var(--blue)"></div>
              <span class="mc-lbl"><Icon name="home" size={14} /></span>
            </div>
            <div class="mc-col">
              <div class="mc-bar" style="height:44px;background:var(--green)"></div>
              <span class="mc-lbl"><Icon name="utensils" size={14} /></span>
            </div>
            <div class="mc-col">
              <div class="mc-bar" style="height:18px;background:var(--orange)"></div>
              <span class="mc-lbl"><Icon name="train" size={14} /></span>
            </div>
            <div class="mc-col">
              <div class="mc-bar" style="height:34px;background:var(--purple)"></div>
              <span class="mc-lbl"><Icon name="gamepad" size={14} /></span>
            </div>
            <div class="mc-col">
              <div class="mc-bar" style="height:14px;background:var(--red)"></div>
              <span class="mc-lbl"><Icon name="coffee" size={14} /></span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .bento-title {
    font-size: clamp(34px, 5vw, 64px);
    font-weight: 500;
    letter-spacing: -0.04em;
    line-height: 1.08;
    margin-bottom: 64px;
    max-width: 16ch;
  }

  /* ── Grid ──────────────────────────────────────────────────── */

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 240px;
    gap: 12px;
  }

  /* ── Base cell ─────────────────────────────────────────────── */

  .bento-cell {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    overflow: hidden;
    position: relative;
    transition: border-color var(--transition), transform var(--transition);
  }

  .bento-cell:hover { border-color: var(--border-hover); transform: translateY(-2px); }

  .bento-medium { grid-column: span 2; }
  .bento-small  { grid-column: span 1; }

  .bento-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .bento-cell-title {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.3;
    color: var(--text);
    white-space: pre-line;
    flex-shrink: 0;
  }

  .bento-cell-desc {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.5;
    flex-shrink: 0;
  }

  .bento-visual { margin-top: auto; min-height: 0; }

  /* ── Hero — Ajout rapide ────────────────────────────────────── */

  .bento-hero {
    grid-column: span 2;
    grid-row: span 2;
    flex-direction: column;
    gap: 0;
    padding: 0;
  }

  /* Texte + iOS badge */
  .hero-content {
    flex-shrink: 0;
    padding: 28px 28px 22px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .hero-title {
    font-size: 26px;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.2;
    color: var(--text);
    white-space: pre-line;
  }

  .ios-badge {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 600;
    color: var(--text-muted);
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 5px 10px;
    width: fit-content;
    margin-top: 4px;
  }
  .ios-icon { font-size: 13px; line-height: 1; }

  /* Panel bas : entry UI à gauche, historique à droite */
  .hero-panel {
    flex: 1;
    min-height: 0;
    background: var(--surface-2);
    border-top: 1px solid var(--border);
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding: 0;
  }

  /* Gauche : saisie de transaction */
  .hp-left {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 24px 28px;
  }

  .hp-amount { display: flex; align-items: baseline; gap: 3px; }
  .hp-currency { font-size: 20px; font-weight: 600; color: var(--text-muted); }
  .hp-num {
    font-size: 52px;
    font-weight: 800;
    letter-spacing: -0.05em;
    color: var(--text);
    line-height: 1;
  }

  .hp-cat {
    font-size: 13px;
    font-weight: 600;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 5px 14px;
    color: var(--text);
  }

  .hp-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    background: var(--accent-dim);
    color: var(--accent);
    border-radius: 100px;
    padding: 8px 20px;
    font-size: 13px;
    font-weight: 700;
    width: 100%;
    max-width: 160px;
  }

  /* Séparateur vertical */
  .hp-divider {
    width: 1px;
    height: 55%;
    background: var(--border);
    flex-shrink: 0;
    align-self: center;
  }

  /* Droite : historique */
  .hp-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 8px;
    padding: 24px 28px;
  }

  .hp-sep-label {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 4px;
  }

  .hp-history { display: flex; flex-direction: column; gap: 6px; }

  .hp-tx {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 7px 10px;
  }

  .hp-tx-label { font-size: 12px; font-weight: 600; color: var(--text); }
  .hp-tx-amt   { font-size: 12px; font-weight: 700; color: var(--text-muted); }

  /* ── Swipe queue ────────────────────────────────────────────── */

  .bento-swipe { background: var(--surface); }

  .swipe-stack {
    position: relative;
    height: 60px;
    margin-bottom: 8px;
  }

  .swipe-card {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 10px 12px;
  }
  .swipe-card-back  { transform: rotate(-3deg) translateY(4px); opacity: 0.45; }
  .swipe-card-front { transform: rotate(1.5deg); }

  .swipe-emoji { font-size: 20px; }
  .swipe-name  { font-size: 10px; font-weight: 600; color: var(--text); font-family: monospace; }
  .swipe-hint  { font-size: 10px; color: var(--text-muted); text-align: center; }

  /* ── Cagnottes ──────────────────────────────────────────────── */

  .bento-savings { background: var(--surface); }

  .savings-list  { display: flex; flex-direction: column; gap: 8px; padding-bottom: 2px; }
  .savings-goal  { display: flex; flex-direction: column; gap: 4px; }
  .sg-header     { display: flex; align-items: center; gap: 5px; }
  .sg-emoji      { font-size: 13px; line-height: 1; }
  .sg-name       { font-size: 11px; font-weight: 600; color: var(--text); flex: 1; }
  .sg-pct        { font-size: 11px; font-weight: 700; color: var(--text-muted); }
  .sg-track      { height: 5px; background: var(--surface-3); border-radius: 3px; overflow: hidden; position: relative; }
  .sg-fill       { position: absolute; inset: 0; right: auto; height: 5px; border-radius: 3px; background: var(--text); }
  .sg-amounts    { display: flex; align-items: baseline; gap: 3px; }
  .sg-current    { font-size: 11px; font-weight: 700; color: var(--text); }
  .sg-target     { font-size: 10px; color: var(--text-muted); }

  /* ── Récurrentes ────────────────────────────────────────────── */

  .recur-list { display: flex; flex-direction: column; gap: 6px; }
  .recur-item {
    display: flex; align-items: center; gap: 8px;
    background: var(--surface-2); border-radius: var(--radius-sm);
    padding: 8px 10px; border: 1px solid var(--border);
  }
  .recur-icon   { font-size: 18px; }
  .recur-info   { display: flex; flex-direction: column; flex: 1; }
  .recur-name   { font-size: 11px; font-weight: 600; color: var(--text); }
  .recur-freq   { font-size: 9px; color: var(--text-muted); margin-top: 1px; }
  .recur-amount { font-size: 11px; font-weight: 700; color: var(--text-muted); white-space: nowrap; }

  /* ── Suggestion intelligente ────────────────────────────────── */

  .bento-smart { background: var(--surface); }

  .smart-card {
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* Zone transaction — haut */
  .smart-header {
    padding: 11px 13px 10px;
    background: var(--surface-2);
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .smart-merchant {
    font-size: 14px;
    font-weight: 800;
    color: var(--text);
    font-family: monospace;
    line-height: 1;
  }
  .smart-meta-row { display: flex; align-items: center; gap: 5px; }
  .smart-meta { font-size: 11px; font-weight: 600; color: var(--text-muted); }
  .smart-dot  { font-size: 10px; color: var(--border-hover); }

  /* Zone suggestion — bas */
  .smart-body {
    padding: 9px 13px 11px;
    background: var(--surface-2);
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .smart-label-row { display: flex; align-items: center; gap: 5px; }
  .smart-spark     { font-size: 10px; color: var(--text-muted); }
  .smart-label-txt {
    font-size: 9px;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }
  .smart-actions { display: flex; align-items: center; gap: 8px; }
  .smart-chip {
    font-size: 13px; font-weight: 700; flex: 1;
    background: var(--surface-3); color: var(--text);
    border: 1px solid var(--border-hover);
    padding: 5px 12px; border-radius: 100px;
  }
  .smart-ok {
    font-size: 13px; font-weight: 700; color: var(--accent);
    background: var(--accent-dim);
    width: 28px; height: 28px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }

  /* ── Répartition 50/30/20 ───────────────────────────────────── */

  .bento-split {
    background: linear-gradient(135deg, var(--surface) 0%, var(--surface-2) 100%);
    border-color: var(--border-hover);
  }

  .split-bars  { display: flex; flex-direction: column; gap: 10px; margin-top: auto; }
  .split-bar   { display: flex; flex-direction: column; gap: 5px; }
  .split-row   { display: flex; justify-content: space-between; align-items: baseline; }
  .split-name  { font-size: 11px; font-weight: 600; color: var(--text-muted); }
  .split-pct   { font-size: 10px; font-weight: 700; }

  .split-track {
    height: 6px;
    flex-shrink: 0;
    background: var(--surface-3);
    border-radius: 3px;
    overflow: hidden;
    position: relative;
  }
  .split-fill {
    position: absolute;
    inset: 0;
    right: auto;
    height: 6px;
    border-radius: 3px;
  }

  /* ── Import CSV ─────────────────────────────────────────────── */

  .import-badge {
    display: flex; flex-direction: column; gap: 4px;
    background: var(--surface-2); border: 1px dashed var(--border-hover);
    border-radius: var(--radius-sm); padding: 14px; align-items: center;
  }
  .import-icon  { font-size: 24px; }
  .import-text  { font-size: 10px; font-weight: 600; color: var(--text); font-family: monospace; }
  .import-count { font-size: 10px; font-weight: 600; color: var(--accent); }

  /* ── Graphiques ─────────────────────────────────────────────── */

  .bento-chart { background: var(--surface); }

  .mc-bars { display: flex; align-items: flex-end; gap: 5px; }
  .mc-col  { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 5px; }
  .mc-bar  { width: 100%; border-radius: 3px 3px 0 0; }
  .mc-lbl  { font-size: 12px; line-height: 1; }

  /* ── Responsive ─────────────────────────────────────────────── */

  @media (max-width: 900px) {
    .bento-grid { grid-template-columns: repeat(2, 1fr); }
    .bento-medium { grid-column: span 2; }
    .bento-small { grid-column: span 1; }
  }

  @media (max-width: 580px) {
    .bento-grid { grid-template-columns: 1fr; grid-auto-rows: auto; }
    .bento-hero, .bento-medium, .bento-small { grid-column: span 1; grid-row: span 1; }
    .bento-cell { min-height: 200px; }
    .bento-hero { min-height: 420px; }
    .hero-panel { flex-direction: column; }
    .hp-divider { width: 55%; height: 1px; }
  }
</style>
